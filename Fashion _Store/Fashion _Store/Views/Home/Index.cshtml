    <script>

        // =========================================================
        // HÀM HỖ TRỢ
        // =========================================================

        function formatCurrency(number) {
            if (number === null || number === undefined || isNaN(number)) return '0 ₫';
            return number.toLocaleString('vi-VN') + ' ₫';
        }

        function getHexColor(tenMau) {
            switch (tenMau.toLowerCase()) {
                case 'đen': return '#000000';
                case 'trắng': return '#FFFFFF';
                case 'đỏ': return '#FF0000';
                case 'xanh navy': return '#000080';
                default: return '#ccc';
            }
        }
        // Toggle Sidebar
        function toggleSidebar() {
            const sidebar = document.getElementById("sidebar");
            const mainContent = document.getElementById("mainContent");
            sidebar.classList.toggle("closed");
            mainContent.classList.toggle("expanded");
        }

        // Change Menu - Modern approach without deprecated 'event'
        function changeMenu(menuId) {
            // Hide all content areas
            const contentAreas = document.querySelectorAll(".content-area");
            contentAreas.forEach((area) => area.classList.remove("active"));

            // Show selected content area
            const targetPage = document.getElementById(menuId);
            if (targetPage) {
                targetPage.classList.add("active");

            // Thêm logic tải dữ liệu cụ thể cho từng trang
            if (menuId === 'dashboard') {
                loadDashboardStats();
                loadLowStockAlerts();
            } else if (menuId === 'products') {
                // Chúng ta sẽ định nghĩa hàm này ở bước tiếp theo (Quản lý Sản phẩm)
                loadProductTable();
            }

            // Thêm logic tải dữ liệu cụ thể cho từng trang
            if (menuId === 'dashboard') {
                loadDashboardStats();
                loadLowStockAlerts();
                loadRecentOrders(); // GỌI HÀM NÀY
            } else if (menuId === 'products') {
                loadProductTable();
            }

            if (menuId === 'dashboard') {
                loadDashboardStats();
                loadLowStockAlerts();
                loadRecentOrders();
                loadTopProducts(); // GỌI HÀM MỚI
            } else if (menuId === 'products') {
                loadProductTable();
            }
        }

        // Update active menu
        const menuItems = document.querySelectorAll(".menu-item a");
            menuItems.forEach((item) => item.classList.remove("active"));

        // Thêm logic tải dữ liệu cụ thể cho từng trang
        if (menuId === 'dashboard') {
            loadDashboardStats();
            loadLowStockAlerts();
        }
        }

        // Add event listeners to menu items
        document.addEventListener("DOMContentLoaded", function () {
        const menuLinks = document.querySelectorAll(".menu-item a");

        menuLinks.forEach((link) => {
            link.addEventListener("click", function (e) {
            e.preventDefault();

            const pageId = this.getAttribute("data-page");

            // Remove active class from all links
            menuLinks.forEach((l) => l.classList.remove("active"));

            // Add active class to clicked link
            this.classList.add("active");

            // Change page
            changeMenu(pageId);
            });
        });
        });

        // Responsive sidebar
        window.addEventListener("resize", function () {
        if (window.innerWidth < 768) {
            document.getElementById("sidebar").classList.add("closed");
            document.getElementById("mainContent").classList.add("expanded");
        } else {
            document.getElementById("sidebar").classList.remove("closed");
            document.getElementById("mainContent").classList.remove("expanded");
        }
        });

        // Initial check
        if (window.innerWidth < 768) {
        document.getElementById("sidebar").classList.add("closed");
        document.getElementById("mainContent").classList.add("expanded");
        }

        // Sửa lại logic DOMContentLoaded để gọi hàm ban đầu (chỉ khi load trang)
        document.addEventListener("DOMContentLoaded", function () {
            // ... (logic menu và responsive giữ nguyên) ...

            // THAY THẾ logic tải dữ liệu ban đầu
            // Khởi tạo Dashboard khi trang tải lần đầu
            loadDashboardStats();
            loadLowStockAlerts();
            loadRecentOrders();
            loadTopProducts();
        });

        // =========================================================
        // CHỨC NĂNG DASHBOARD
        // =========================================================

        // Hàm 1: Tải dữ liệu cho 4 Thẻ Thống Kê Nhanh (Sử dụng API GetDashboardStats)
        async function loadDashboardStats() {
            try {
                const response = await fetch('/AdminApi/GetDashboardStats');
                const result = await response.json();

                if (result.success) {
                    // 1. Doanh Thu Hôm Nay (Stat Card Blue)
                    document.querySelector('.stat-card.blue .stat-info h3').textContent = formatCurrency(result.doanhThuHomNay);

                    // 2. Sản Phẩm Sắp Hết (Stat Card Orange) - Đã có trong v_ThongKeNhanh
                    document.querySelector('.stat-card.orange .stat-info h3').textContent = result.sanPhamSapHet;

                    // 3. Đơn Hàng Hoàn Thành (Có thể dùng thay cho 'Đơn hàng mới' nếu không có API riêng)
                    // Cần API riêng để lấy số đơn Chờ Xử Lý, tạm dùng 0 nếu chưa có.
                    // document.querySelector('.stat-card.green .stat-info h3').textContent = result.donHangHoanThanh; 

                    // 4. Khách Hàng Hoạt Động (Nếu chưa có API khách hàng mới hôm nay)
                    // document.querySelector('.stat-card.purple .stat-info h3').textContent = result.khachHangHoatDong; 

                    // Giả lập cho 2 thẻ còn lại nếu chưa có API chi tiết
                    document.querySelector('.stat-card.green .stat-info h3').textContent = 0; // Thay bằng API Đơn hàng mới
                    document.querySelector('.stat-card.purple .stat-info h3').textContent = 0; // Thay bằng API Khách hàng mới
                }
            } catch (error) {
                console.error("Lỗi khi tải Dashboard Stats:", error);
            }
        }

        // Hàm 2: Tải dữ liệu cho Cảnh Báo Tồn Kho Thấp (Sử dụng API GetLowStockAlerts)
        async function loadLowStockAlerts() {
            try {
                const response = await fetch('/AdminApi/GetLowStockAlerts');
                const result = await response.json();
                const tableBody = document.querySelector('#dashboard .card:last-child .data-table tbody');
                tableBody.innerHTML = ''; // Xóa dữ liệu mẫu

                if (result.success && result.data && result.data.length > 0) {
                    result.data.forEach(item => {
                        const stockStatus = item.SoLuongTon <= 5 ? 'danger' : 'warning';
                        const statusText = item.SoLuongTon <= 5 ? 'Cần nhập gấp' : 'Sắp hết';

                        const row = `
                    <tr>
                        <td><strong>${item.MaSP}</strong></td>
                        <td>${item.TenSP}</td>
                        <td>
                            <span class="color-dot" style="background: ${getHexColor(item.TenMau)}"></span> ${item.TenMau}
                        </td>
                        <td>${item.TenSize}</td>
                        <td><span class="stock-low">${item.SoLuongTon}</span></td>
                        <td><span class="badge ${stockStatus}">${statusText}</span></td>
                        <td>
                            <button class="btn-action primary" data-ctsp="${item.MaCTSP}">
                                <i class="fas fa-plus"></i> Nhập hàng
                            </button>
                        </td>
                    </tr>
                `;
                        tableBody.innerHTML += row;
                    });
                } else {
                    tableBody.innerHTML = '<tr><td colspan="7" style="text-align: center; color: #666;">Không có sản phẩm nào sắp hết hàng (ngưỡng < 10).</td></tr>';
                }
            } catch (error) {
                console.error("Lỗi khi tải Cảnh Báo Tồn Kho:", error);
            }
        }

        // Hàm 3: Tải dữ liệu cho Đơn Hàng Gần Đây (Recent Orders)
        async function loadRecentOrders() {
            try {
                const response = await fetch('/AdminApi/GetRecentOrders');
                const result = await response.json();
                const tableBody = document.querySelector('#dashboard .dashboard-grid .data-table tbody');
                tableBody.innerHTML = '<tr><td colspan="5" style="text-align: center;">Đang tải đơn hàng...</td></tr>'; // Loading

                if (result.success && result.data && result.data.length > 0) {
                    tableBody.innerHTML = ''; // Xóa loading
                    result.data.forEach(item => {
                        let badgeClass;
                        // Ánh xạ trạng thái SQL sang CSS class
                        if (item.TrangThai === 'Hoàn thành') {
                            badgeClass = 'success';
                        } else if (item.TrangThai === 'Chờ xử lý') {
                            badgeClass = 'warning';
                        } else if (item.TrangThai === 'Đang giao') {
                            badgeClass = 'info';
                        } else {
                            badgeClass = 'danger';
                        }

                        // Chuyển đổi NgayBan sang định dạng hiển thị (ví dụ: "10 phút trước")
                        // Để đơn giản, ta chỉ hiển thị ngày/giờ, việc tính "x phút trước" phức tạp hơn
                        const time = new Date(item.NgayBan).toLocaleString('vi-VN', {
                            hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit'
                        });

                        const row = `
                    <tr>
                        <td><strong>${item.MaPhieuBan}</strong></td>
                        <td>${item.TenKH}</td>
                        <td>${formatCurrency(item.TongTien)}</td>
                        <td><span class="badge ${badgeClass}">${item.TrangThai}</span></td>
                        <td>${time}</td>
                    </tr>
                `;
                        tableBody.innerHTML += row;
                    });
                } else {
                    tableBody.innerHTML = '<tr><td colspan="5" style="text-align: center; color: #666;">Không có đơn hàng gần đây.</td></tr>';
                }
            } catch (error) {
                console.error("Lỗi khi tải Đơn Hàng Gần Đây:", error);
            }
        }
        // Hàm 4: Tải dữ liệu cho Sản Phẩm Bán Chạy (Top Products)
        async function loadTopProducts() {
            try {
                const response = await fetch('/AdminApi/GetTopSellingProducts');
                const result = await response.json();
                const productListContainer = document.querySelector('#dashboard .dashboard-grid .product-list');
                productListContainer.innerHTML = '<p style="text-align: center; color: #999;">Đang tải sản phẩm...</p>'; // Loading

                if (result.success && result.data && result.data.length > 0) {
                    productListContainer.innerHTML = ''; // Xóa loading
                    result.data.forEach(item => {
                        // Tạo một hình ảnh giả (Placeholder) vì bạn chưa có thư mục ảnh
                        const imageUrl = 'https://ui-avatars.com/api/?name=' + item.MaSP + '&background=f39c12&color=fff&size=50';

                        const revenue = formatCurrency(item.TongDoanhThu);

                        const productItem = `
                    <div class="product-item">
                        <img src="${imageUrl}" alt="${item.TenSP}" />
                        <div class="product-details">
                            <h4>${item.TenSP}</h4>
                            <p>Đã bán: <strong>${item.TongSoLuongBan}</strong> sản phẩm</p>
                        </div>
                        <div class="product-revenue">
                            <strong>${revenue}</strong>
                        </div>
                    </div>
                `;
                        productListContainer.innerHTML += productItem;
                    });
                } else {
                    productListContainer.innerHTML = '<p style="padding: 15px; text-align: center; color: #666;">Chưa có sản phẩm nào được bán trong kỳ này.</p>';
                }
            } catch (error) {
                console.error("Lỗi khi tải Sản Phẩm Bán Chạy:", error);
            }
        }
    </script>
